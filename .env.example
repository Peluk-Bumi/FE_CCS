# --- POLYGON MAINNET ---
VITE_BLOCKCHAIN_CHAIN_ID=137
VITE_BLOCKCHAIN_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
VITE_BLOCKCHAIN_CONTRACT_ADDRESS=0xA4b62924be4dC1e61046804f59f3B8FA98Bc37e0
VITE_BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com
VITE_BLOCKCHAIN_NETWORK_LABEL=Polygon Mainnet
