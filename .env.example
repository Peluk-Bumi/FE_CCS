VITE_BLOCKCHAIN_WALLET_ADDRESS=0xYourBroadcasterWalletAddress

# Rate Limiting Configuration
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
