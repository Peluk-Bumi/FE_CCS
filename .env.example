# ✅ API Configuration
VITE_API_MODE=auto
VITE_API_URL_PRODUCTION=https://apibeccs.nexcube-digital.com/api
VITE_API_URL_LOCAL=http://127.0.0.1:8000/api
# Optional override (if set, this takes priority when VITE_API_MODE=auto)
# VITE_API_URL=https://apibeccs.nexcube-digital.com/api
VITE_APP_NAME=CCS Project
VITE_APP_VERSION=1.4.0

# Blockchain Configuration (Frontend - No Secrets)
VITE_BLOCKCHAIN_CHAIN_ID=80002
VITE_BLOCKCHAIN_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_BLOCKCHAIN_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
VITE_BLOCKCHAIN_EXPLORER_URL=https://amoy.polygonscan.com
VITE_BLOCKCHAIN_NETWORK_LABEL=Polygon Amoy Testnet
VITE_BLOCKCHAIN_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Fallback RPC URLs (comma-separated, validated)
VITE_BLOCKCHAIN_FALLBACK_RPC_URLS=https://rpc-amoy.polygon.technology

# Gas Configuration (optional)
VITE_BLOCKCHAIN_GAS_LIMIT=300000
VITE_BLOCKCHAIN_MAX_GAS_PRICE=50000000000

# Dev-only: floating blockchain status widget (hidden when PROD or set to false)
# VITE_DEBUG_BLOCKCHAIN=false

# DEPRECATED: Will be removed in v2.0
# VITE_POLYGON_CHAIN_ID (use VITE_BLOCKCHAIN_CHAIN_ID)
# VITE_POLYGON_RPC_URL (use VITE_BLOCKCHAIN_RPC_URL)
# VITE_CONTRACT_ADDRESS (use VITE_BLOCKCHAIN_CONTRACT_ADDRESS)
# VITE_BLOCKCHAIN_EXPLORER_BASE_URL (use VITE_BLOCKCHAIN_EXPLORER_URL)
# VITE_WALLET_PRIVATE_KEY (REMOVE - security risk, backend only)
# VITE_INFURA_API_SECRET (backend only)
# VITE_INFURA_GAS_API_URL (backend only)

# ✅ Rate Limiting Configuration
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
