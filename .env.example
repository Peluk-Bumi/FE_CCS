# ==============================================================================
# FRONTEND SERVICE CONFIGURATION (FE_CCS)
# ==============================================================================

VITE_APP_NAME="Peluk Bumi EMS Frontend"
# VITE_APP_VERSION is managed automatically from package.json version in vite.config.js
# VITE_APP_VERSION=2.0.0
VITE_API_MODE=auto

# ------------------------------------------------------------------------------
# 🌐 API CONFIGURATION
# ------------------------------------------------------------------------------
VITE_API_URL_PRODUCTION=https://apibeccs.nexcube-digital.com/api
VITE_API_URL_LOCAL=http://127.0.0.1:8000/api

# ------------------------------------------------------------------------------
# 🔗 BLOCKCHAIN CONFIGURATION (PUBLIC INFO ONLY)
# ------------------------------------------------------------------------------
# Most transaction logic is now handled by BC_CCS (port 4000)

# --- OPTION 1: POLYGON MAINNET ---
VITE_BLOCKCHAIN_CHAIN_ID=137
VITE_BLOCKCHAIN_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
VITE_BLOCKCHAIN_CONTRACT_ADDRESS=0xA4b62924be4dC1e61046804f59f3B8FA98Bc37e0
VITE_BLOCKCHAIN_EXPLORER_URL=https://polygonscan.com
VITE_BLOCKCHAIN_NETWORK_LABEL=Polygon Mainnet
VITE_BLOCKCHAIN_FALLBACK_RPC_URLS=https://rpc-mainnet.matic.quiknode.pro

# --- OPTION 2: ETHEREUM SEPOLIA (Testnet) ---
# VITE_BLOCKCHAIN_CHAIN_ID=11155111
# VITE_BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# VITE_BLOCKCHAIN_CONTRACT_ADDRESS=0x5C5F6CE61647600bB8c04F59c0F2B493EBE78DDF
# VITE_BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io
# VITE_BLOCKCHAIN_NETWORK_LABEL=Sepolia Testnet
# VITE_BLOCKCHAIN_FALLBACK_RPC_URLS=https://rpc.sepolia.org

# --- OPTION 3: HARDHAT LOCAL / FORK (Testing) ---
# VITE_BLOCKCHAIN_CHAIN_ID=31337
# VITE_BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# VITE_BLOCKCHAIN_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# VITE_BLOCKCHAIN_EXPLORER_URL=http://localhost:8545
# VITE_BLOCKCHAIN_NETWORK_LABEL=Hardhat Local
# VITE_BLOCKCHAIN_FALLBACK_RPC_URLS=

# ------------------------------------------------------------------------------
# ⚙️ PERFORMANCE & DEBUG
# ------------------------------------------------------------------------------
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
VITE_DEBUG_BLOCKCHAIN=false
