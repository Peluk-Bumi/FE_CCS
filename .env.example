# ✅ API Configuration
VITE_API_MODE=auto
VITE_API_URL_PRODUCTION=https://apibeccs.nexcube-digital.com/api
VITE_API_URL_LOCAL=http://127.0.0.1:8000/api
# Optional override (if set, this takes priority when VITE_API_MODE=auto)
# VITE_API_URL=https://apibeccs.nexcube-digital.com/api
VITE_APP_NAME=CCS Project
VITE_APP_VERSION=1.3.0

# ✅ Blockchain Configuration - Polygon Amoy Testnet
VITE_POLYGON_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_INFURA_API_SECRET=your_infura_api_secret
VITE_INFURA_GAS_API_URL=https://gas.api.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_POLYGON_CHAIN_ID=80002
VITE_BLOCKCHAIN_EXPLORER_BASE_URL=https://amoy.polygonscan.com
VITE_BLOCKCHAIN_NETWORK_LABEL=Polygon Amoy Testnet

# ✅ Wallet Setup - Private Key (JANGAN COMMIT KE GIT!)
# ⚠️ SECURITY WARNING: Jangan share private key ke siapapun!
# Dapatkan dari MetaMask:
#   1. Klik Avatar (kanan atas)
#   2. Account Details
#   3. Show Private Key
#   4. Paste di sini (tanpa 0x di awal)
# VITE_WALLET_ADDRESS=0xYourWalletAddressHere
# VITE_WALLET_PRIVATE_KEY=your_private_key_here

# For hardhat deployment
# PRIVATE_KEY=your_private_key_here
# SEPOLIA_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ✅ Smart Contract Address (setelah deploy di Remix)
# Deploy ke https://remix.ethereum.org kemudian paste address di sini
VITE_CONTRACT_ADDRESS=0x5C5F6CE61647600bB8c04F59c0F2B493EBE78DDF

# ✅ Optional: Alchemy RPC (backup)
# VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ✅ Rate Limiting Configuration
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
