# ✅ API Configuration
VITE_API_MODE=auto
VITE_API_URL_LOCAL=http://127.0.0.1:8000/api
VITE_API_URL_PRODUCTION=https://apibeccs.nexcube-digital.com/api
# Optional direct override
# VITE_API_URL=http://localhost:8000/api

# ✅ Blockchain Configuration (Polygon L2)
VITE_CONTRACT_ADDRESS=0x5C5F6CE61647600bB8c04F59c0F2B493EBE78DDF
VITE_POLYGON_CHAIN_ID=80002
VITE_BLOCKCHAIN_EXPLORER_BASE_URL=https://amoy.polygonscan.com
VITE_BLOCKCHAIN_NETWORK_LABEL=Polygon Amoy Testnet

# ✅ PRIMARY RPC (Polygon Amoy testnet)
VITE_POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# Optional explicit variable used by hardhat + frontend
# VITE_POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ✅ Polygon Mainnet RPC (optional for production)
# VITE_POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# ✅ Polygon / Infura API
# VITE_INFURA_API_SECRET=your_infura_api_secret
# VITE_POLYGON_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_PROJECT_ID
# VITE_INFURA_GAS_API_URL=https://gas.api.infura.io/v3/YOUR_PROJECT_ID

# ✅ Hardhat Deploy Variables
# TARGET_CHAIN=amoy
# POLYGON_AMOY_URL=https://rpc-amoy.polygon.technology
# POLYGON_MAINNET_URL=https://polygon-rpc.com
# PRIVATE_KEY=your_private_key_without_quotes

# ✅ Wallet Configuration (NEVER commit private keys!)
# VITE_WALLET_ADDRESS=0xYourWalletAddressHere
# VITE_WALLET_PRIVATE_KEY=your_private_key_here

# ✅ Rate Limiting Configuration
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
