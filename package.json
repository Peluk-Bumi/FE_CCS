    "ethers": "^6.15.0",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.12",
    "heic2any": "^0.0.4",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.539.0",
    "pdf-lib": "^1.17.1",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.5.0",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.1.1",
