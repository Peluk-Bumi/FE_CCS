{
  "name": "pelukbumi-ccs-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Frontend aplikasi Peluk Bumi untuk sistem Carbon Capture and Storage (CCS) - Platform monitoring transparansi data konservasi lingkungan",
  "homepage": "https://pelukbumi.id",
  "repository": {
    "type": "git",
    "url": "https://github.com/pelukbumi/ccs-frontend.git"
  },
  "keywords": [
    "pelukbumi",
    "carbon-capture-storage",
    "ccs",
    "environmental-conservation",
    "blockchain",
    "transparency",
    "react",
    "laravel"
  ],
  "author": "Peluk Bumi Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm exec --yes vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "node -e \"const fs = require('fs'); const path = require('path'); const dirs = ['node_modules', 'dist']; dirs.forEach(d => { const p = path.join(process.cwd(), d); if(fs.existsSync(p)) fs.rmSync(p, {recursive: true}); });\" && npm cache clean --force",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.6",
