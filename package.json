    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@yudiel/react-qr-scanner": "^2.3.1",
    "@zxing/library": "^0.21.3",
    "axios": "^1.11.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
